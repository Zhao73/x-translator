{
  "manifest_version": 3,
  "name": "X Translator",
  "version": "3.0.0",
  "description": "Smart inline translation for X (Twitter) posts — paragraph by paragraph",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/translator.js"],
      "css": ["content/translator.css"],
      "run_at": "document_idle"
    }
  ]
}